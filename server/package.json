{
  "name": "@zeropay/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "node dist/worker.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts || true",
    "migrate:up": "migrate-mongo up",
    "migrate:down": "migrate-mongo down",
    "migrate:status": "migrate-mongo status",
    "test": "vitest run"
  },
  "dependencies": {
    "@blockfrost/blockfrost-js": "^5.5.0",
    "@google/genai": "^0.2.0",
    "@meshsdk/core": "^1.7.7",
    "@sentry/node": "^10.53.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@upstash/redis": "^1.32.0",
    "@zeropay/shared-types": "file:../shared/shared-types",
    "axios": "^1.7.2",
    "bcryptjs": "^3.0.3",
    "bech32": "^2.0.0",
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "firebase-admin": "^12.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^3.3.7",
    "socket.io": "^4.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.2",
    "migrate-mongo": "^14.0.7",
    "tsx": "^4.15.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.7"
  }
}
