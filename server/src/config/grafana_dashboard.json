{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "title": "API Request Rate (HTTP/sec)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(zeropay_requests_total[1m])",
          "legendFormat": "HTTP Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "reqps"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "title": "API Latency Percentiles (ms)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "zeropay_response_duration_ms{quantile=\"0.5\"}",
          "legendFormat": "p50 Median",
          "refId": "A"
        },
        {
          "expr": "zeropay_response_duration_ms{quantile=\"0.95\"}",
          "legendFormat": "p95 Percentile",
          "refId": "B"
        },
        {
          "expr": "zeropay_response_duration_ms{quantile=\"0.99\"}",
          "legendFormat": "p99 Anomalous",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "ms"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "title": "Active WebSocket Connections",
      "type": "gauge",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "zeropay_socket_connections_total",
          "legendFormat": "Sockets active",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 10000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5000 },
              { "color": "red", "value": 8500 }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 4,
      "title": "Circuit Breaker State Map (0=CLOSED, 1=OPEN, 2=HALF_OPEN)",
      "type": "state-timeline",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "zeropay_circuit_breaker_state",
          "legendFormat": "breaker: {{breaker}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED (Normal)", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "OPEN (Tripped)", "color": "red" } } },
            { "type": "value", "options": { "2": { "text": "HALF_OPEN (Testing)", "color": "orange" } } }
          ]
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 5,
      "title": "Circuit Breaker Caught Failures (Cumulative)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "zeropay_circuit_breaker_failures",
          "legendFormat": "breaker: {{breaker}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars"
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "id": 6,
      "title": "BullMQ Worker Queues Depth - Waiting Status",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "zeropay_queue_jobs_total{state=\"waiting\"}",
          "legendFormat": "queue: {{queue}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "id": 7,
      "title": "BullMQ Queue Job Failures",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "zeropay_queue_jobs_total{state=\"failed\"}",
          "legendFormat": "queue: {{queue}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          }
        }
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["zeropay", "production", "metrics"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
  },
  "title": "ZeroPay Production Observability Dashboard",
  "timezone": "browser",
  "version": 1
}
